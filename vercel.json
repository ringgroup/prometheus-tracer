{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth-meta-as" },
    { "source": "/.well-known/oauth-authorization-server/(.*)", "destination": "/api/oauth-meta-as" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/oauth-meta-prm" },
    { "source": "/.well-known/oauth-protected-resource/(.*)", "destination": "/api/oauth-meta-prm" }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [ { "key": "X-Content-Type-Options", "value": "nosniff" } ] }
  ]
}
