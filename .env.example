# Prometheus Tracer — GitHub OAuth login config.
# Set these as Environment Variables in the Vercel project
# (Settings → Environment Variables), NOT committed to git.

# From your GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Comma-separated GitHub usernames allowed to view the dashboard.
# Leave EMPTY to allow any GitHub user to sign in.
#   e.g. ALLOWED_GITHUB_USERS=ringgroup
ALLOWED_GITHUB_USERS=
