# Prometheus Tracer — environment variables (set in Vercel project settings).

# --- GitHub OAuth (https://github.com/settings/developers) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session cookie signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional allow-list of GitHub usernames. LEAVE EMPTY to let any GitHub user
# sign in (each new user starts with an empty tracker). @ringgroup is seeded
# with the original protocol history regardless.
ALLOWED_GITHUB_USERS=

# --- Vercel KV (per-user storage) ---
# These are injected automatically when you attach a Vercel KV store to the
# project (Vercel dashboard → Storage → KV → Connect Project). No manual entry
# needed; listed here for reference.
KV_REST_API_URL=
KV_REST_API_TOKEN=
